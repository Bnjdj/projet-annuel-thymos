        "duration": "2-5 minutes"
      },
      {
        "name": "Physiological Sigh",
        "description": "Double inhale through nose, long exhale through mouth",
        "use_case": "Immediate stress relief, during walkout",
        "duration": "1-3 breaths as needed"
      },
      {
        "name": "Wim Hof Method",
        "description": "30 power breaths followed by breath hold",
        "use_case": "Morning routine, building stress tolerance",
        "duration": "3 rounds, 15 minutes total"
      },
      {
        "name": "Nasal Breathing Training",
        "description": "Breathe only through nose during low-intensity training",
        "use_case": "Building aerobic base, CO2 tolerance",
        "duration": "During warm-ups and cool-downs"
      }
    ],
    "pre_fight_routines": [
      {
        "name": "Fight Week Mental Protocol",
        "days_out_7": "Review game plan, watch opponent tape one last time",
