  "weight_cutting": {
    "overview": "Weight cutting is the practice of rapidly losing weight before weigh-ins to compete in a lower weight class",
    "safe_protocols": {
      "gradual_cut": {
        "description": "Slow caloric reduction over 8-12 weeks",
        "max_weight_loss_per_week_kg": 0.5,
        "method": "Reduce calories by 300-500 daily, maintain protein intake",
        "recommended_for": "Fighters cutting less than 5% bodyweight"
      },
      "water_cut": {
        "description": "Manipulation of water and sodium in final week",
        "timeline": {
          "7_days_out": "Increase water intake to 8L/day, high sodium",
          "5_days_out": "Maintain 8L water, begin reducing sodium",
          "3_days_out": "Reduce water to 4L, low sodium",
          "2_days_out": "Reduce water to 2L, no sodium",
          "1_day_out": "Sip water only, hot bath/sauna to cut final kg",
          "weigh_in_day": "No water until after weigh-in"
        },
        "max_safe_water_cut_percent": 8,
        "recommended_for": "Experienced fighters with medical supervision"
      }
    },
    "rehydration_protocol": {
      "immediately_after_weighin": "Sip electrolyte solution (Pedialyte/ORS)",
      "first_2_hours": "500ml-1L electrolyte drink, small easily digestible meal",
      "2_to_6_hours": "Continue hydrating, eat carbohydrate-rich meals",
      "6_to_12_hours": "Normal meals, continue fluids, aim for clear urine",
      "target_rehydration": "Regain 5-8% of bodyweight before fight"
    },
    "danger_signs": [
      "Dizziness or fainting",
      "Rapid heart rate at rest",
      "Dark brown urine",
      "Muscle cramps that won't resolve",
      "Confusion or disorientation",
      "Kidney pain"
    ],
    "guidelines": [
      "Never cut more than 10% of bodyweight total",
      "Water cut should not exceed 6-8% bodyweight",
      "Always have medical supervision",
      "Practice cuts before actual fight week",
      "Consider moving up in weight if cuts are too difficult",
      "Young/amateur fighters should cut minimally or not at all"
    ]
  },

  "mental_preparation": {
    "visualization": {
      "description": "Mental rehearsal of fight scenarios",
      "techniques": [
        {
          "name": "Outcome Visualization",
          "description": "Visualize winning the fight - hand raised, belt around waist",
          "frequency": "Daily, 5-10 minutes",
          "timing": "Morning or before sleep"
        },
        {
          "name": "Process Visualization",
          "description": "Mentally rehearse specific techniques, combos, and transitions",
          "frequency": "Daily, 10-15 minutes",
          "timing": "After training or before sleep"
        },
        {
          "name": "Adversity Visualization",
          "description": "Visualize overcoming challenges - being rocked, taken down, cut",
          "frequency": "3x per week",
          "timing": "During camp"
